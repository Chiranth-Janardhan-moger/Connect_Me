# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGO=mongodb://localhost:27017/connect-me
# For production: mongodb+srv://username:password@cluster.mongodb.net/connect-me

# Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Expo Push Notifications (Optional but recommended for production)
# Get your access token from: https://expo.dev/accounts/[account]/settings/access-tokens
# Benefits: Higher rate limits, better monitoring, access to analytics
EXPO_ACCESS_TOKEN=

# Upstash Redis (Optional - for caching and performance)
# Get free Redis from: https://upstash.com/
# Benefits: Faster location updates, reduced database load
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# CORS Configuration (Optional)
# CORS_ORIGIN=https://yourdomain.com

# Logging (Optional)
# LOG_LEVEL=info