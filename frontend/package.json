{
  "name": "bms-connect",
  "version": "1.4.0",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "reset-project": "node ./scripts/reset-project.js",
    "build:android": "set NODE_ENV=production && expo run:android --variant release",
    "build:aab": "cd android && ./gradlew bundleRelease",
    "build:apk-v8": "cd android && ./gradlew assembleRelease -PreactNativeArchitectures=arm64-v8a",
    "build:apk-v7": "cd android && ./gradlew assembleRelease -PreactNativeArchitectures=armeabi-v7a",
    "build:split-apks": "npm run build:apk-v8 && npm run build:apk-v7",
    "build:lean": "cd android && ./gradlew assembleRelease -Pandroid.enableMinifyInReleaseBuilds=true -Pandroid.enableShrinkResourcesInReleaseBuilds=true",
    "build:clean": "cd android && ./gradlew clean",
    "build:optimize": "npx expo-optimize",
    "build:production": "npm run build:clean && npm run build:optimize && npm run build:split-apks",
    "build:aab:production": "npm run build:clean && npm run build:optimize && npm run build:aab",
    "build:analyze": "cd android && ./gradlew assembleRelease && echo 'Analyze APK with Android Studio (Build > Analyze APK)'"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/geolocation": "^3.4.0",
    "@react-native-community/netinfo": "^11.4.1",
    "crypto-js": "^4.2.0",
    "expo": "^54.0.16",
    "expo-build-properties": "^1.0.9",
    "expo-constants": "~18.0.9",
    "expo-device": "^8.0.9",
    "expo-font": "~14.0.9",
    "expo-linear-gradient": "^15.0.7",
    "expo-linking": "~8.0.8",
    "expo-location": "^19.0.7",
    "expo-notifications": "^0.32.12",
    "expo-router": "^6.0.13",
    "expo-splash-screen": "~31.0.10",
    "expo-system-ui": "~6.0.7",
    "lottie-react-native": "^7.3.4",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-webview": "13.15.0",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@react-native-community/cli": "^20.0.2",
    "@react-native-community/cli-platform-android": "^20.0.2",
    "@types/react": "~19.1.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "react-native-gradle-plugin": "^0.71.19",
    "typescript": "~5.9.2"
  }
}
